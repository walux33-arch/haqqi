# Haqqi - Moroccan Legal AI Platform
# Copy this file to .env and fill in your keys
# Get GROQ_API_KEY from https://console.groq.com
# Get Supabase credentials from https://supabase.com (project: fttpoxsggrwtthtjhal)

GROQ_API_KEY=your_groq_api_key_here
SUPABASE_URL=https://fttpoxsggrwtthtjhal.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Optional: Tesseract OCR path (Windows only, defaults to system PATH)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# WhatsApp Bot (Twilio)
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
# WhatsApp sender number (assigned by Twilio)
TWILIO_WHATSAPP_FROM=+14155238886
# Verify token for Meta webhook verification
WHATSAPP_VERIFY_TOKEN=haqqi_verify_2026
